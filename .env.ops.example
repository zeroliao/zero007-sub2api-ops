# Local Codex/PowerShell connection settings.
# Copy this file to .env.ops and fill in the values.

SUB2API_SSH_HOST=api.zero007.chat
SUB2API_SSH_USER=
SUB2API_SSH_PORT=22
SUB2API_REMOTE_DIR=/opt/sub2api-deploy
SUB2API_HEALTH_URL=https://api.zero007.chat/health
SUB2API_PROJECT_NAME=sub2api-deploy

# Git-backed deployment settings. Deploy actions fetch this repository on the
# server and check out the same pushed commit before running.
SUB2API_OPS_REPO=git@github.com:zeroliao/zero007-sub2api-ops.git
SUB2API_OPS_REMOTE=origin
SUB2API_OPS_BRANCH=main
SUB2API_REMOTE_OPS_DIR=/home/your_ssh_user/zero007-sub2api-ops
SUB2API_REMOTE_GIT_SSH_KEY=/home/your_ssh_user/.ssh/zero007_sub2api_ops_deploy

# Optional. Leave empty to use the default SSH identity.
SUB2API_SSH_KEY=

# Emergency only. When true, deploy actions allow local uncommitted files to be
# uploaded directly instead of using the Git-backed server checkout.
SUB2API_ALLOW_DIRTY_DEPLOY=false
